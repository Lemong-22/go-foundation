{
  "name": "entropy-course",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "@types/bun": "^1.3.4",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.9",
      "@types/express": "^5.0.1",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@trpc/client": "^11.16.0",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev --filter=web",
    "dev:server": "turbo run dev --filter=server",
    "db:push": "turbo run db:push --filter=@entropy-course/db",
    "db:studio": "turbo run db:studio --filter=@entropy-course/db",
    "db:generate": "turbo run db:generate --filter=@entropy-course/db",
    "db:migrate": "turbo run db:migrate --filter=@entropy-course/db",
    "db:seed": "turbo run db:seed --filter=@entropy-course/db",
    "db:start": "turbo run db:start --filter=@entropy-course/db",
    "db:watch": "turbo run db:watch --filter=@entropy-course/db",
    "db:stop": "turbo run db:stop --filter=@entropy-course/db",
    "db:down": "turbo run db:down --filter=@entropy-course/db",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
    "@entropy-course/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@entropy-course/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.1"
}
